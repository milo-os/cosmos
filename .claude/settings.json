{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git mv:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(go build:*)",
      "Bash(go mod tidy:*)",
      "Bash(go list:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "WebSearch"
    ]
  },
  "extraKnownMarketplaces": {
    "datum-claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "datum-cloud/claude-code-plugins"
      }
    }
  },
  "enabledPlugins": {
    "datum-platform@datum-claude-code-plugins": true,
    "datum-gtm@datum-claude-code-plugins": true
  }
}
