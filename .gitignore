bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ── Go build cache / coverage ───────────────────────────────────────
coverage.out
coverage.txt
*.coverprofile
go.build/

# ── Generated files (regenerate with `task generate` / `task manifests`)
