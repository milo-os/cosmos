# to regenerate, then commit the changes. Do not hand-edit.

# ── IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.sublime-project
*.sublime-workspace

# ── macOS ───────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ─────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux / file-manager trash ──────────────────────────────────────
.Trash-*/

