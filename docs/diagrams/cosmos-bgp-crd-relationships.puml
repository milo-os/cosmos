@startuml cosmos-bgp-crd-relationships
' Source for docs/cosmos-bgp-crd-relationships.png
' Rendered via: plantuml docs/diagrams/cosmos-bgp-crd-relationships.puml
' Do not edit the PNG directly — edit this file and re-render.
'
' CRD set as of 2026-06-18
' API group:
'   bgp.miloapis.com/v1alpha1  — all BGP CRDs

!$NEW_C4_STYLE = 1
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
!include datum-theme.puml

LAYOUT_TOP_DOWN()

title Cosmos BGP CRDs — Component Relationships

' ── POP cluster / Infra cluster ───────────────────────────────────────────

Boundary(pop_infra, "POP cluster + Infra cluster", "[system]") {
    System(router, "BGPRouter", "bgp.miloapis.com/v1alpha1\n\nBGP routing context — local AS,\nrouter ID, address families, roles.\nOne per plane per node.")
    Container(peer, "BGPPeer", "bgp.miloapis.com/v1alpha1", "One side of a BGP session\non matched routers.\nPropagated via Karmada.")
    System(advert, "BGPAdvertisement", "bgp.miloapis.com/v1alpha1\n\nPrefix advertisement.\nLoopbacks, SRv6 locators,\nunderlay prefixes.")
    System(routepolicy, "BGPRoutePolicy", "bgp.miloapis.com/v1alpha1\n\nImport / export route filtering.\nOrdered terms with sequence numbers.")
}

' ── Management cluster ────────────────────────────────────────────────────

Boundary(mgmt, "Management cluster", "[system]") {
    System_Ext(externalpeer, "BGPExternalPeer", "bgp.miloapis.com/v1alpha1\n\nExternal peer identity record.\nToR, transit provider, customer edge.\nRegistry only — never propagated.")
}

' ── Layout hints ──────────────────────────────────────────────────────────

Lay_R(router, peer)
Lay_D(router, advert)
Lay_D(peer, routepolicy)
Lay_R(advert, routepolicy)
Lay_D(pop_infra, mgmt)

' ── Relationships ─────────────────────────────────────────────────────────

Rel(peer, router, "routerRef /\nrouterSelector")
Rel(advert, router, "routerRef")
Rel(routepolicy, router, "routerRef /\nrouterSelector")

SHOW_LEGEND()
@enduml
