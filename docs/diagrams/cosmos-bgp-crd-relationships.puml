@startuml cosmos-bgp-crd-relationships
' Source for docs/cosmos-bgp-crd-relationships.png
' Rendered via: plantuml docs/diagrams/cosmos-bgp-crd-relationships.puml
' Do not edit the PNG directly — edit this file and re-render.
'
' CRD set as of 2026-06-03
' API groups:
'   providers.bgp.miloapis.com/v1alpha1  — BGPProvider
'   bgp.miloapis.com/v1alpha1            — all other CRDs

!$NEW_C4_STYLE = 1
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
!include datum-theme.puml

LAYOUT_TOP_DOWN()

title Cosmos BGP CRDs — Component Relationships

AddRelTag("dashed", $lineStyle=DashedLine(), $lineColor=$DATUM_MIDNIGHT_FJORD, $textColor=$DATUM_MIDNIGHT_FJORD)

' ── POP cluster / Infra cluster ───────────────────────────────────────────

Boundary(pop_infra, "POP cluster + Infra cluster", "[system]") {
    System(provider, "BGPProvider", "providers.bgp.miloapis.com/v1alpha1\n\nConnection config — daemon type,\naddress, transport, auth.\nAuto-bootstrapped for local daemons.\nManually provisioned for remotes.")
    System(instance, "BGPInstance", "bgp.miloapis.com/v1alpha1\n\nBGP speaker config — AS number,\nrouter ID, address families,\ntimers, best-path policy.")
    Container(peer, "BGPPeer", "bgp.miloapis.com/v1alpha1", "One side of a BGP session\non matched providers.\nGenerated by SessionReconciler.\nNever written directly.")
    System(advert, "BGPAdvertisement", "bgp.miloapis.com/v1alpha1\n\nPrefix advertisement.\nLoopbacks, SRv6 locators,\nunderlay prefixes.")
    System(routepolicy, "BGPRoutePolicy", "bgp.miloapis.com/v1alpha1\n\nImport / export route filtering.\nPriority-ordered policy statements.")
}

' ── BGP daemons (outside cluster boundary) ────────────────────────────────

Component(frr, "FRR", "BGP daemon", "Underlay daemon\nIPv6 unicast")
Component(gobgp, "GoBGP", "BGP daemon", "Overlay daemon\nL3VPN / VPNv6")

' ── Management cluster ────────────────────────────────────────────────────

Boundary(mgmt, "Management cluster", "[system]") {
    System(session, "BGPSession", "bgp.miloapis.com/v1alpha1\n\nBilateral session intent.\nWritten by mgmt cluster.\nPropagated via Karmada.\nGenerates BGPPeer resources.")
    System_Ext(externalpeer, "BGPExternalPeer", "bgp.miloapis.com/v1alpha1\n\nExternal peer identity record.\nToR, transit provider, customer edge.\nDeletion blocked while referenced.")
}

' ── Layout hints ──────────────────────────────────────────────────────────

Lay_R(provider, instance)
Lay_R(instance, peer)
Lay_D(provider, advert)
Lay_D(peer, routepolicy)
Lay_R(advert, routepolicy)
Lay_R(peer, frr)
Lay_D(frr, gobgp)
Lay_D(pop_infra, mgmt)
Lay_R(session, externalpeer)

' ── Relationships ─────────────────────────────────────────────────────────

Rel(instance, provider, "providerSelector")
Rel(peer, instance, "instanceRef")
Rel(peer, provider, "providerRef /\nproviderSelector")
Rel(advert, instance, "instanceRef")
Rel(advert, peer, "peerSelector (optional)", $tags="dashed")
Rel(routepolicy, instance, "instanceRef")
Rel(routepolicy, peer, "peerSelector (optional)", $tags="dashed")
Rel(session, peer, "generates", $tags="dashed")
Rel(session, externalpeer, "fromExternalPeerRef")
Rel(provider, frr, "configures")
Rel(provider, gobgp, "configures")

SHOW_LEGEND()
@enduml
