@startuml design-resource-flow
!$NEW_C4_STYLE = 1
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml
!include datum-theme.puml

title BGP CRD Resource Relationships

System(router, "BGPRouter", "Routing context:\nAS number, router ID,\naddress families, roles")
System(peer, "BGPPeer", "BGP session:\nrouterRef / routerSelector,\naddress, peerASN")
System(advert, "BGPAdvertisement", "Prefixes to advertise:\nrouterRef, addressFamily,\nprefixes, communities")
System(rpolicy, "BGPRoutePolicy", "Import/export filters:\nrouterRef / routerSelector,\ndirection, ordered terms")
System_Ext(externalpeer, "BGPExternalPeer", "External peer registry\n(management cluster)")

Rel_D(peer, router, "routerRef / routerSelector")
Rel_D(advert, router, "routerRef")
Rel_D(rpolicy, router, "routerRef / routerSelector")

SHOW_LEGEND()
@enduml
